{
  "kind": "collectionType",
  "collectionName": "promotions",
  "info": {
    "singularName": "promotion",
    "pluralName": "promotions",
    "displayName": "Promotion"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string"
    },
    "slug": {
      "type": "uid",
      "targetField": "name"
    },
    "value": {
      "type": "integer",
      "required": true
    },
    "startAt": {
      "type": "datetime"
    },
    "endAt": {
      "type": "datetime"
    },
    "products": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::product.product",
      "mappedBy": "promotions"
    },
    "variants": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::variant.variant",
      "inversedBy": "promotions"
    },
    "categories": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::category.category",
      "mappedBy": "promotions"
    },
    "temp_categories": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::temp-category.temp-category",
      "inversedBy": "promotions"
    },
    "active": {
      "type": "boolean"
    }
  }
}
